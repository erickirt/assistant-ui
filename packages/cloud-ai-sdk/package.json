{
  "name": "@assistant-ui/cloud-ai-sdk",
  "version": "0.1.25",
  "description": "Standalone Vercel AI SDK hooks backed by Assistant Cloud persistence",
  "keywords": [
    "assistant",
    "cloud",
    "ai",
    "chat",
    "assistant-ui",
    "ai-sdk"
  ],
  "author": "AgentbaseAI Inc.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "aui-build",
    "test": "pnpm run test:v7 && pnpm run test:peer-v6 && pnpm run test:types:peer-v6",
    "test:v7": "vitest run",
    "test:peer-v6": "vitest run --config vitest.peer-v6.config.ts",
    "test:types:peer-v6": "tsc --noEmit --project tsconfig.peer-v6.json",
    "test:watch": "vitest"
  },
  "dependencies": {
    "assistant-cloud": "workspace:*"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^3.0.0 || ^4.0.0",
    "@types/react": "*",
    "ai": "^6.0.0 || ^7.0.0",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/react": "^4.0.30",
    "@ai-sdk/react-v3": "npm:@ai-sdk/react@^3.0.211",
    "@assistant-ui/x-buildutils": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "ai": "^7.0.28",
    "ai-v6": "npm:ai@^6.0.209",
    "assistant-stream": "^0.3.26",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://www.assistant-ui.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assistant-ui/assistant-ui.git",
    "directory": "packages/cloud-ai-sdk"
  },
  "bugs": {
    "url": "https://github.com/assistant-ui/assistant-ui/issues"
  }
}
