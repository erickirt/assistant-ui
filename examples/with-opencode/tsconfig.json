{
  "extends": "@assistant-ui/x-buildutils/ts/next",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@assistant-ui/react-opencode": [
        "../../packages/react-opencode/src/index.ts"
      ],
      "@/components/assistant-ui/*": [
        "../../packages/ui/src/components/assistant-ui/*"
      ],
      "@/components/icons/*": ["../../packages/ui/src/components/icons/*"],
      "@/components/ui/*": [
        "../../packages/ui/src/components/ui/base/*",
        "../../packages/ui/src/components/ui/radix/*"
      ],
      "@/components/ui/radix/*": [
        "../../packages/ui/src/components/ui/radix/*"
      ],
      "@/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@/lib/utils": ["../../packages/ui/src/lib/utils"],
      "@assistant-ui/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
